{
  "name": "metastrip",
  "version": "1.0.0",
  "description": "Cross-platform image metadata cleaner",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "client": "vite src --port 5173",
    "server": "node server/index.js",
    "electron": "concurrently \"npm run server\" \"wait-on http://localhost:3001 && electron .\"",
    "build": "vite build",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "exifr": "^7.1.3",
    "jszip": "^3.10.1",
    "multer": "^1.4.5-lts.1",
    "sharp": "^0.33.2"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "vite": "^5.1.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.metastrip.app",
    "productName": "MetaStrip",
    "directories": { "output": "dist-electron" },
    "files": ["dist/**/*", "electron/**/*", "server/**/*", "node_modules/**/*"],
    "mac": { "target": "dmg" },
    "win": { "target": "nsis" },
    "linux": { "target": "AppImage" }
  }
}
